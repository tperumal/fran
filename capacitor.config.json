{
  "appId": "com.toddperumal.fran",
  "appName": "FRAN",
  "webDir": "dist",
  "server": {
    "url": "https://app.onlyfran.co",
    "cleartext": false,
    "allowNavigation": ["app.onlyfran.co"]
  },
  "ios": {
    "contentInset": "automatic",
    "scheme": "FRAN"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 1500,
      "backgroundColor": "#ffffff"
    },
    "StatusBar": {
      "style": "Dark"
    }
  }
}
